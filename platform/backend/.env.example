# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=okinawa
DATABASE_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_NAME=okinawa
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# JWT
JWT_SECRET=CHANGE_ME_USE_MIN_32_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_USE_MIN_32_CHARS_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# CSRF
CSRF_SECRET=CHANGE_ME_USE_MIN_32_CHARS_RANDOM_STRING

# Field Encryption (AES-256 for PII: MFA secrets, PIX keys, card data)
FIELD_ENCRYPTION_KEY=CHANGE_ME_USE_MIN_32_CHARS_RANDOM_STRING

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# OAuth - Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key
APPLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/apple/callback

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_CALLBACK_URL=http://localhost:3000/api/v1/auth/microsoft/callback

# AWS S3 (Optional - para storage de imagens)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=okinawa-uploads

# Payment Gateway (Asaas)
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WEBHOOK_URL=http://localhost:3000/api/v1/webhooks/asaas
ASAAS_ENVIRONMENT=sandbox

# AI Services
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
LOVABLE_API_KEY=your-lovable-api-key

# Firebase Cloud Messaging (Push Notifications)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@okinawa.com
SENDGRID_FROM_NAME=Project Okinawa

# AWS SNS (SMS)
AWS_SNS_ACCESS_KEY=your-aws-sns-access-key
AWS_SNS_SECRET_KEY=your-aws-sns-secret-key
AWS_SNS_REGION=us-east-1

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:8081,http://localhost:19000,http://localhost:19006
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# Swagger
SWAGGER_ENABLED=false  # Only enable in development
SWAGGER_TITLE=Project Okinawa API
SWAGGER_DESCRIPTION=Restaurant Technology Platform API
SWAGGER_VERSION=1.0
SWAGGER_PATH=docs
