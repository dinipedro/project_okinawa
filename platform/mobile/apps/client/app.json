{
  "expo": {
    "name": "Okinawa Cliente",
    "slug": "okinawa-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "okinawa",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.okinawa.client",
      "minimumOsVersion": "14.0",
      "associatedDomains": ["applinks:noowebr.com", "applinks:*.noowebr.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "Permite escanear QR codes de mesas e produtos",
        "NSLocationWhenInUseUsageDescription": "Permite encontrar restaurantes próximos",
        "NSLocationAlwaysUsageDescription": "Permite notificações baseadas em localização"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.okinawa.client",
      "minSdkVersion": 24,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "noowebr.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "*.noowebr.com"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite escanear QR codes"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permite encontrar restaurantes próximos"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B35"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "owner": "okinawa"
  }
}
