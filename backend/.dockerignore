# ===========================================
# Project Okinawa - Docker Ignore
# Excludes unnecessary files from Docker build
# ===========================================

# Dependencies
node_modules
npm-debug.log
yarn-error.log
package-lock.json.bak

# Build output
dist
build

# IDE and editors
.idea
.vscode
*.swp
*.swo
*.sublime-*
.editorconfig

# OS files
.DS_Store
Thumbs.db
*.log

# Environment files (NEVER include in image)
.env
.env.*
!.env.example

# Tests (not needed in production)
coverage
*.spec.ts
*.test.ts
**/__tests__
**/__mocks__
jest.config.*
test

# Git
.git
.gitignore
.gitattributes

# Documentation (reduce image size)
README.md
CHANGELOG.md
CONTRIBUTING.md
docs
*.md

# Docker files
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.circleci
.travis.yml
azure-pipelines.yml

# Linting and formatting
.eslintrc*
.prettierrc*
.eslintignore
.prettierignore

# TypeScript build info
tsconfig.tsbuildinfo
*.tsbuildinfo

# Temporary files
tmp
temp
*.tmp
*.bak
